# 婴儿安全监控系统环境配置

# =================================
# 基础配置
# =================================
NODE_ENV=production
LOG_LEVEL=info

# =================================
# 服务端口配置
# =================================
BACKEND_PORT=8080
FRONTEND_PORT=5173
VISION_PORT=8001
AGENT_PORT=8002

# =================================
# 数据库配置
# =================================
DB_DSN=data/baby_safety.db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# =================================
# 缓存配置
# =================================
CACHE_ENABLED=true
CACHE_TTL=5m
CACHE_MAX_ENTRIES=1000

# =================================
# 通知配置
# =================================
# 钉钉机器人配置
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 邮件通知配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# =================================
# 安全配置
# =================================
# API访问密钥（用于服务间通信）
API_SECRET_KEY=your-secret-key-here

# JWT配置（如果需要认证）
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# CORS允许的域名
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# 监控配置
# =================================
# Prometheus配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana配置
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_PORT=3000

# 健康检查配置
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s

# =================================
# Vision服务配置
# =================================
# YOLO模型配置
YOLO_WEIGHTS=/models/yolov8n.pt
YOLO_CONFIDENCE=0.25
YOLO_IMAGE_SIZE=640

# 摄像头配置
CAMERA_DEFAULT_FPS=1.0
CAMERA_DEFAULT_RESOLUTION=640
CAMERA_MAX_RETRY_COUNT=3
CAMERA_RETRY_DELAY=5s

# 处理线程池配置
VISION_WORKERS=4
VISION_QUEUE_SIZE=100

# =================================
# Agent服务配置
# =================================
# 风险阈值配置
RISK_THRESHOLD=0.7
HIGH_RISK_THRESHOLD=0.9

# AI模型配置（如果使用LLM）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=150

# =================================
# 文件存储配置
# =================================
# 数据目录
DATA_DIR=./data
MODELS_DIR=./data/models
LOGS_DIR=./logs

# 文件上传限制
MAX_UPLOAD_SIZE=10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,mp4,avi

# 日志轮转配置
LOG_MAX_SIZE=100MB
LOG_MAX_AGE=30d
LOG_MAX_BACKUPS=10

# =================================
# 性能优化配置
# =================================
# HTTP服务器配置
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# 连接池配置
HTTP_MAX_IDLE_CONNS=100
HTTP_MAX_CONNS_PER_HOST=10
HTTP_IDLE_CONN_TIMEOUT=90s

# =================================
# 开发环境配置
# =================================
# 调试模式
DEBUG=false
VERBOSE_LOGGING=false

# 热重载
HOT_RELOAD=false
DEV_PROXY=http://localhost:8080

# 测试配置
ENABLE_TEST_ENDPOINTS=false
MOCK_CAMERA_ENABLED=false

# =================================
# 生产环境配置
# =================================
# SSL/TLS配置
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# 反向代理配置
PROXY_ENABLED=false
PROXY_HOST=nginx
PROXY_PORT=80

# 容器资源限制
MEMORY_LIMIT=512M
CPU_LIMIT=1.0